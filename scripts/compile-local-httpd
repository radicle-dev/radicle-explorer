#!/usr/bin/env bash
set -e

echo "🔨 Compiling local radicle-httpd..."

# radicle-httpd lives in the Cargo workspace under crates/. Building the
# workspace member places the binary at the workspace-root target/, not under
# the crate directory.
cargo build -p radicle-httpd

BIN="target/debug/radicle-httpd"
if [ ! -f "$BIN" ]; then
  echo "❌ Compilation failed - binary not found"
  exit 1
fi

# Create target directory
mkdir -p tests/tmp/bin/httpd/local

# Copy binary to test location
cp "$BIN" tests/tmp/bin/httpd/local/radicle-httpd

echo "✅ Local radicle-httpd compiled and ready at tests/tmp/bin/httpd/local/radicle-httpd"
